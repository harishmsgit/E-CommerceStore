aws_region         = "ap-south-1"
deployment_mode    = "existing"
account_id         = "495013583028"
instance_id        = "i-0523c91cfc25de02b"
vpc_id             = "vpc-0714e469a68ae1721"
subnet_id          = "subnet-00bf4ffcdb135dfba"
security_group_id  = "sg-0fe408481fc8b427d"
instance_type      = "t3.medium"
key_name           = ""
vpc_cidr           = "10.10.0.0/16"
public_subnet_cidr = "10.10.1.0/24"
dockerhub_username = "harsen"
image_tag          = "latest"
ssh_user           = "ec2-user"
ssh_private_key_path = "C:/path/to/your-key.pem"

# Keep false if SG already has HTTP 80 open. Set true to let Terraform add it.
open_frontend_port = false

# Required for Terraform remote-exec in existing mode unless SSH is already open.
open_ssh_port    = true
ssh_allowed_cidr = "0.0.0.0/0"

# Optional: expose service_urls from Terraform outputs. Prefer a /32 CIDR for testing.
open_service_ports         = false
service_ports_allowed_cidr = "0.0.0.0/0"
